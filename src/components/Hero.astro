---
// Hero & Stats Component
---

<section class="py-8 px-4">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-8">
      <h1 class="text-3xl md:text-4xl font-bold mb-2">
        ¡Hola! 👋
      </h1>
      <p class="text-surface-500 dark:text-surface-400" id="currentDate"></p>
    </div>
    
    <!-- Stats Cards -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
      <!-- Progress Card -->
      <div class="bg-white dark:bg-surface-800 rounded-2xl p-5 shadow-sm border border-surface-200 dark:border-surface-700">
        <div class="flex items-center gap-3 mb-3">
          <div class="w-10 h-10 rounded-xl bg-primary-100 dark:bg-primary-900/50 flex items-center justify-center">
            <svg class="w-5 h-5 text-primary-600 dark:text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
            </svg>
          </div>
          <span class="text-sm font-medium text-surface-500 dark:text-surface-400">Progreso</span>
        </div>
        <div class="relative pt-1">
          <div class="flex mb-2 items-center justify-between">
            <div>
              <span class="text-2xl font-bold text-surface-900 dark:text-surface-50" id="progressPercent">0%</span>
            </div>
          </div>
          <div class="overflow-hidden h-2 mb-4 text-xs flex rounded-full bg-surface-200 dark:bg-surface-700">
            <div id="progressBar" style="width: 0%" class="shadow-none flex flex-col text-center whitespace-nowrap text-white justify-center bg-primary-500 transition-all duration-500"></div>
          </div>
        </div>
      </div>
      
      <!-- Tasks Card -->
      <div class="bg-white dark:bg-surface-800 rounded-2xl p-5 shadow-sm border border-surface-200 dark:border-surface-700">
        <div class="flex items-center gap-3 mb-3">
          <div class="w-10 h-10 rounded-xl bg-green-100 dark:bg-green-900/50 flex items-center justify-center">
            <svg class="w-5 h-5 text-green-600 dark:text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/>
            </svg>
          </div>
          <span class="text-sm font-medium text-surface-500 dark:text-surface-400">Tareas</span>
        </div>
        <p class="text-2xl font-bold text-surface-900 dark:text-surface-50">
          <span id="completedTasks">0</span>/<span id="totalTasks">0</span>
        </p>
        <p class="text-xs text-surface-400 dark:text-surface-500">completadas</p>
      </div>
      
      <!-- Meals Card -->
      <div class="bg-white dark:bg-surface-800 rounded-2xl p-5 shadow-sm border border-surface-200 dark:border-surface-700">
        <div class="flex items-center gap-3 mb-3">
          <div class="w-10 h-10 rounded-xl bg-orange-100 dark:bg-orange-900/50 flex items-center justify-center">
            <svg class="w-5 h-5 text-orange-600 dark:text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
            </svg>
          </div>
          <span class="text-sm font-medium text-surface-500 dark:text-surface-400">Comidas</span>
        </div>
        <p class="text-2xl font-bold text-surface-900 dark:text-surface-50" id="mealsToday">0</p>
        <p class="text-xs text-surface-400 dark:text-surface-500">registradas hoy</p>
      </div>
      
      <!-- Pending Card -->
      <div class="bg-white dark:bg-surface-800 rounded-2xl p-5 shadow-sm border border-surface-200 dark:border-surface-700">
        <div class="flex items-center gap-3 mb-3">
          <div class="w-10 h-10 rounded-xl bg-yellow-100 dark:bg-yellow-900/50 flex items-center justify-center">
            <svg class="w-5 h-5 text-yellow-600 dark:text-yellow-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <span class="text-sm font-medium text-surface-500 dark:text-surface-400">Pendientes</span>
        </div>
        <p class="text-2xl font-bold text-surface-900 dark:text-surface-50" id="pendingTasks">0</p>
        <p class="text-xs text-surface-400 dark:text-surface-500">por hacer</p>
      </div>
    </div>
  </div>
</section>

<script>
  function updateDate() {
    const options: Intl.DateTimeFormatOptions = { 
      weekday: 'long', 
      year: 'numeric', 
      month: 'long', 
      day: 'numeric' 
    };
    const dateEl = document.getElementById('currentDate');
    if (dateEl) {
      dateEl.textContent = new Date().toLocaleDateString('es-ES', options);
    }
  }
  
  function updateStats() {
    const stored = localStorage.getItem('colochatime_data');
    if (!stored) {
      updateDate();
      return;
    }
    
    try {
      const data = JSON.parse(stored);
      const today = new Date().toDateString();
      
      const todayTasks = data.tasks.filter((t: any) => 
        new Date(t.createdAt).toDateString() === today
      );
      
      const completedTasks = todayTasks.filter((t: any) => t.completed).length;
      const totalTasks = todayTasks.length;
      const progressPercent = totalTasks > 0 ? Math.round((completedTasks / totalTasks) * 100) : 0;
      
      const todayMeals = data.meals.filter((m: any) => 
        new Date(m.createdAt).toDateString() === today
      ).length;
      
      // Update DOM
      const progressPercentEl = document.getElementById('progressPercent');
      const progressBar = document.getElementById('progressBar');
      const completedTasksEl = document.getElementById('completedTasks');
      const totalTasksEl = document.getElementById('totalTasks');
      const mealsTodayEl = document.getElementById('mealsToday');
      const pendingTasksEl = document.getElementById('pendingTasks');
      
      if (progressPercentEl) progressPercentEl.textContent = `${progressPercent}%`;
      if (progressBar) progressBar.style.width = `${progressPercent}%`;
      if (completedTasksEl) completedTasksEl.textContent = completedTasks.toString();
      if (totalTasksEl) totalTasksEl.textContent = totalTasks.toString();
      if (mealsTodayEl) mealsTodayEl.textContent = todayMeals.toString();
      if (pendingTasksEl) pendingTasksEl.textContent = (totalTasks - completedTasks).toString();
      
      updateDate();
    } catch (e) {
      console.error('Error updating stats:', e);
      updateDate();
    }
  }
  
  // Update on load and periodically
  updateStats();
  setInterval(updateStats, 5000);
  
  // Listen for custom events
  window.addEventListener('colochatime:update', updateStats);
</script>
