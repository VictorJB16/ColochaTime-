---
// Task Manager Component - Diseño limpio
---

<section class="py-6 px-6">
  <div class="max-w-4xl mx-auto">
    
    <!-- Header -->
    <div class="flex items-center justify-between mb-4">
      <div class="flex items-center gap-3">
        <div class="w-8 h-8 rounded-lg bg-green-100 dark:bg-green-900/30 flex items-center justify-center">
          <svg class="w-4 h-4 text-green-600 dark:text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/>
          </svg>
        </div>
        <h2 class="text-base font-semibold text-surface-900 dark:text-white">Tareas</h2>
      </div>
    </div>
    
    <!-- Add Task Form -->
    <form id="taskForm" class="flex gap-2 mb-4">
      <div class="flex-1 relative">
        <input 
          type="text" 
          id="taskInput" 
          placeholder="Nueva tarea..."
          class="w-full px-4 py-2.5 rounded-xl border border-surface-300 dark:border-surface-600 bg-white dark:bg-surface-800 text-surface-900 dark:text-white placeholder-surface-400 dark:placeholder-surface-500 focus:outline-none focus:ring-2 focus:ring-primary-500/50 focus:border-transparent transition-all text-sm"
          maxlength="100"
          required
        />
      </div>
      <input 
        type="time" 
        id="taskTime"
        class="px-3 py-2.5 rounded-xl border border-surface-300 dark:border-surface-600 bg-white dark:bg-surface-800 text-surface-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-primary-500/50 focus:border-transparent transition-all text-sm w-32"
      />
      <button 
        type="submit"
        class="px-4 py-2.5 rounded-xl bg-primary-600 hover:bg-primary-700 text-white font-medium transition-colors flex items-center gap-2"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
        </svg>
      </button>
    </form>
    
    <!-- Task List -->
    <div id="taskList" class="space-y-2">
      <div id="emptyTasks" class="text-center py-8">
        <svg class="w-10 h-10 mx-auto mb-3 text-surface-300 dark:text-surface-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
        </svg>
        <p class="text-sm text-surface-400 dark:text-surface-500">No hay tareas</p>
      </div>
    </div>
    
    <!-- Clear All Button -->
    <div id="clearSection" class="hidden mt-6 pt-4 border-t border-surface-200 dark:border-surface-700">
      <button 
        id="clearAllBtn"
        class="w-full py-2 rounded-lg text-sm text-red-500 hover:bg-red-50 dark:hover:bg-red-900/20 transition-colors flex items-center justify-center gap-2"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0"/>
        </svg>
        Eliminar todas las tareas
      </button>
    </div>
  </div>
</section>

<script>
  const STORAGE_KEY = 'colochatime_data';
  
  function getData() {
    const stored = localStorage.getItem(STORAGE_KEY);
    return stored ? JSON.parse(stored) : { tasks: [], meals: [], settings: {}, meta: {} };
  }
  
  function saveData(data) {
    data.meta.lastUpdated = new Date().toISOString();
    localStorage.setItem(STORAGE_KEY, JSON.stringify(data));
    window.dispatchEvent(new CustomEvent('colochatime:update'));
  }
  
  function addTask(text, time = null) {
    const data = getData();
    const newTask = {
      id: crypto.randomUUID(),
      text,
      completed: false,
      createdAt: new Date().toISOString(),
      time
    };
    data.tasks.push(newTask);
    saveData(data);
    renderTasks();
  }
  
  function toggleTask(taskId) {
    const data = getData();
    const task = data.tasks.find((t: any) => t.id === taskId);
    if (task) {
      task.completed = !task.completed;
      task.completedAt = task.completed ? new Date().toISOString() : null;
      saveData(data);
      renderTasks();
    }
  }
  
  function deleteTask(taskId) {
    const data = getData();
    data.tasks = data.tasks.filter((t: any) => t.id !== taskId);
    saveData(data);
    renderTasks();
  }
  
  function renderTasks() {
    const data = getData();
    const today = new Date().toDateString();
    
    // Mostrar TODAS las tareas (no solo de hoy) porque los datos son permanentes
    const tasks = [...data.tasks].sort((a: any, b: any) => {
      // Primero incomplete, luego por fecha de creación
      if (a.completed !== b.completed) return a.completed ? 1 : -1;
      return new Date(b.createdAt).getTime() - new Date(a.createdAt).getTime();
    });
    
    const taskList = document.getElementById('taskList');
    const emptyTasks = document.getElementById('emptyTasks');
    const clearSection = document.getElementById('clearSection');
    
    if (!taskList) return;
    
    // Toggle clear section visibility
    if (clearSection) {
      clearSection.classList.toggle('hidden', tasks.length === 0);
    }
    
    if (tasks.length === 0) {
      taskList.innerHTML = `
        <div id="emptyTasks" class="text-center py-8">
          <svg class="w-10 h-10 mx-auto mb-3 text-surface-300 dark:text-surface-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
          </svg>
          <p class="text-sm text-surface-400 dark:text-surface-500">No hay tareas</p>
        </div>
      `;
      return;
    }
    
    taskList.innerHTML = tasks.map((task: any) => `
      <div class="group flex items-center gap-3 p-3 rounded-xl bg-white dark:bg-surface-800 border border-surface-200/50 dark:border-surface-700/50 hover:border-surface-300 dark:hover:border-surface-600 transition-colors ${task.completed ? 'opacity-60' : ''}">
        <button 
          class="task-checkbox flex-shrink-0 w-5 h-5 rounded-md border-2 flex items-center justify-center transition-all ${
            task.completed 
              ? 'bg-green-500 border-green-500' 
              : 'border-surface-300 dark:border-surface-500 hover:border-primary-500'
          }"
          onclick="toggleTask('${task.id}')"
        >
          ${task.completed ? `
            <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
            </svg>
          ` : ''}
        </button>
        
        <div class="flex-1 min-w-0">
          <p class="text-sm text-surface-900 dark:text-white ${task.completed ? 'line-through text-surface-400' : ''} break-words">
            ${escapeHtml(task.text)}
          </p>
          <div class="flex items-center gap-3 mt-1">
            ${task.time ? `
              <span class="text-xs text-surface-400 dark:text-surface-500 flex items-center gap-1">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                ${task.time}
              </span>
            ` : ''}
            <span class="text-xs text-surface-400 dark:text-surface-500">
              ${formatDate(task.createdAt)}
            </span>
          </div>
        </div>
        
        <button 
          class="opacity-0 group-hover:opacity-100 p-1.5 rounded-lg text-surface-400 hover:text-red-500 hover:bg-red-50 dark:hover:bg-red-900/20 transition-all"
          onclick="deleteTask('${task.id}')"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
          </svg>
        </button>
      </div>
    `).join('');
  }
  
  function escapeHtml(text: string): string {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }
  
  function formatDate(dateStr: string): string {
    const date = new Date(dateStr);
    const today = new Date();
    const yesterday = new Date(today);
    yesterday.setDate(yesterday.getDate() - 1);
    
    if (date.toDateString() === today.toDateString()) return 'Hoy';
    if (date.toDateString() === yesterday.toDateString()) return 'Ayer';
    
    return date.toLocaleDateString('es-ES', { day: 'numeric', month: 'short' });
  }
  
  // Event Listeners
  document.getElementById('taskForm')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const input = document.getElementById('taskInput') as HTMLInputElement;
    const timeInput = document.getElementById('taskTime') as HTMLInputElement;
    
    if (input.value.trim()) {
      addTask(input.value.trim(), timeInput.value || null);
      input.value = '';
      timeInput.value = '';
      input.focus();
    }
  });
  
  // Clear all tasks
  document.getElementById('clearAllBtn')?.addEventListener('click', () => {
    if (confirm('¿Eliminar todas las tareas?')) {
      const data = getData();
      data.tasks = [];
      saveData(data);
      renderTasks();
    }
  });
  
  // Initial render
  renderTasks();
</script>
