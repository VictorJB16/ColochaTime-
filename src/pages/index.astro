---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Stats from '../components/Stats.astro';
import TaskManager from '../components/TaskManager.astro';
import PetTracker from '../components/PetTracker.astro';
import Timeline from '../components/Timeline.astro';
import Footer from '../components/Footer.astro';
import DevData from '../components/DevData.astro';
---

<Layout title="ColochaTime">
  <div class="min-h-screen flex flex-col pb-8">
    <Header />
    <DevData />
    
    <main class="flex-1">
      <Stats />
      <TaskManager />
      <PetTracker />
      <Timeline />
    </main>
    
    <Footer />
  </div>
</Layout>
